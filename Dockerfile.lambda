# Lambda container image for the 3 MCP target Lambdas (data-tools,
# memory-log, brokerage proxy). Uses the official AWS Lambda Python base
# image which has awslambdaric pre-installed at a known-executable path.
#
# Same source tree as Dockerfile.agentcore, but lambda-specific layout.

FROM --platform=linux/arm64 public.ecr.aws/lambda/python:3.12

# Install dependencies into the Lambda runtime directory.
COPY pyproject.toml ${LAMBDA_TASK_ROOT}/
COPY README.md ${LAMBDA_TASK_ROOT}/
COPY tradingagents ${LAMBDA_TASK_ROOT}/tradingagents
COPY cli ${LAMBDA_TASK_ROOT}/cli
COPY main.py ${LAMBDA_TASK_ROOT}/
COPY infra/lambdas ${LAMBDA_TASK_ROOT}/infra/lambdas

WORKDIR ${LAMBDA_TASK_ROOT}
RUN pip install --no-cache-dir ".[bedrock]" && \
    pip install --no-cache-dir requests boto3

# CMD is overridden per Lambda via ImageConfig.Command in CDK; this is
# just a placeholder to satisfy the Lambda base image requirement.
CMD ["infra.lambdas.data_tools.handler.handler"]
